# Copy this file to .env and fill in the values for your environment.
# Never commit .env — it's already in .gitignore.

# --- Database (required) ----------------------------------------------------
# Local dev: a local Postgres instance. Production: your Render Postgres
# "External Database URL" (or "Internal Database URL" if the app and DB run
# in the same Render private network).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sybaubetting"

# Used only by DB integration tests (tests/db/*) — a second, disposable
# database so tests never touch your dev data.
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sybaubetting_test"

# --- Redis (optional) --------------------------------------------------------
# Leave unset to run without caching — every code path that reads Redis
# falls back to computing the value directly. Only worth adding once the
# dashboard endpoint is under real load.
REDIS_URL=""

# --- Odds provider (required for real data; omit to use the mock provider) --
# Get a key at https://the-odds-api.com. Server-side only — never exposed to
# the browser. If unset, the app and worker fall back to a small built-in
# mock dataset so local dev works out of the box.
ODDS_API_KEY=""
# Which provider implementation to use. "the-odds-api" is the only real
# provider implemented today; "mock-provider" forces the offline mock
# dataset even if ODDS_API_KEY is set (useful for demos/tests).
ODDS_API_PROVIDER="the-odds-api"

# Player props and futures each cost extra provider requests per worker
# cycle (one call per event for props, one per league for futures). Real
# odds API plans have a limited monthly quota -- set either to "false" to
# skip that ingestion and conserve quota if game odds + bet tracking is
# your priority over full props/futures coverage.
INCLUDE_PLAYER_PROPS="true"
INCLUDE_FUTURES="true"

# --- Worker / cron ------------------------------------------------------
# Shared secret an external scheduler (e.g. a Render Cron Job hitting an
# HTTP trigger) could present — currently unused since the worker is
# invoked as a CLI process, kept here for the recommended-next-step of
# adding an HTTP-triggered variant. Safe to leave as-is.
CRON_SECRET="change-me"

# --- App -------------------------------------------------------------------
# Single-user MVP: the email associated with the one seeded user /
# placed bets. Change to your own email before deploying.
DEFAULT_USER_EMAIL="you@example.com"

# --- Access control (required for any deployment reachable by other people) --
# There is no per-user login system -- this is a single shared passphrase
# gating the whole app (every page and every /api/* route) via
# src/middleware.ts. Leave unset for local dev (no login prompt at all).
# MUST be set before sharing a deployed link with anyone -- without it the
# app, including your bet history and the ability to create/edit data, is
# completely open to whoever has the URL.
APP_PASSWORD=""
